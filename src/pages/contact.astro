---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
---

<BaseLayout title="Contact" description="Get in touch with ApiCare — for orders, partnerships, press, or to learn about our beekeepers and traceability work.">

  <section class="container-content pt-22 md:pt-30 pb-22">
    <p class="eyebrow mb-6">Contact</p>
    <h1 class="font-serif text-5xl md:text-6xl font-light tracking-tight text-ink leading-[1.05] text-balance max-w-3xl mb-10">
      Write to us.
    </h1>
    <p class="text-lg text-ink-soft max-w-xl leading-relaxed">
      Press, partnerships, retail enquiries, or just questions about our honey — we read every email.
    </p>
  </section>

  <div class="hairline container-content"></div>

  <section class="container-content py-22">
    <div class="grid md:grid-cols-12 gap-12">

      <!-- Contact info -->
      <div class="md:col-span-4">
        <p class="eyebrow mb-6">Direct</p>
        <p class="text-base text-ink mb-2">
          <a href={`mailto:${site.email}`} class="no-underline border-b border-ink hover:text-honey hover:border-honey transition-colors">{site.email}</a>
        </p>
        <p class="text-base text-ink-soft mb-12">{site.phone}</p>

        <p class="eyebrow mb-6">Where</p>
        <address class="not-italic text-base text-ink-soft leading-relaxed">
          {site.address.line1}<br />
          {site.address.line2}
        </address>
      </div>

      <!-- Form -->
      <div class="md:col-span-7 md:col-start-6">
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Connect this form to Formspree, Basin, or your preferred handler.')">
          <div>
            <label for="purpose" class="eyebrow block mb-3">I'm writing about</label>
            <select id="purpose" name="purpose" class="w-full bg-transparent border-b border-ink py-2 text-base focus:outline-none focus:border-honey">
              <option>An order or product question</option>
              <option>Retail or distribution enquiry</option>
              <option>Press or media</option>
              <option>Partnership / collaboration</option>
              <option>Something else</option>
            </select>
          </div>

          <div>
            <label for="name" class="eyebrow block mb-3">Name</label>
            <input type="text" id="name" name="name" required class="w-full bg-transparent border-b border-ink py-2 text-base focus:outline-none focus:border-honey" />
          </div>

          <div>
            <label for="email" class="eyebrow block mb-3">Email</label>
            <input type="email" id="email" name="email" required class="w-full bg-transparent border-b border-ink py-2 text-base focus:outline-none focus:border-honey" />
          </div>

          <div>
            <label for="message" class="eyebrow block mb-3">Message</label>
            <textarea id="message" name="message" rows="5" required class="w-full bg-transparent border-b border-ink py-2 text-base focus:outline-none focus:border-honey resize-none"></textarea>
          </div>

          <button type="submit" class="btn-primary">Send</button>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>
