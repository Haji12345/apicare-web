---
// ========================================================================
// Home Page
// ========================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import JarSilhouette from '../components/JarSilhouette.astro';
import { getFeaturedHoney, getHoneyByDistrict } from '../data/honey.js';
import { getPublicBeekeepers, getTotalBeekeeperCount } from '../data/beekeepers.js';

const featured = getFeaturedHoney();
const byDistrict = getHoneyByDistrict();
const previewBeekeepers = getPublicBeekeepers().slice(0, 3);
const totalBeekeepers = getTotalBeekeeperCount();
---

<BaseLayout title="ApiCare">

  <!-- ====================================================================
       HERO — Editorial, restrained, single moment
       ==================================================================== -->
  <section class="hero relative h-screen overflow-hidden">
    <div class="hero-slider">
      <img src="/images/hero1.jpg" alt="" class="active" />
      <img src="/images/hero2.jpg" alt="" />
      <img src="/images/hero3.jpg" alt="" />
      <img src="/images/hero4.jpg" alt="" />
      <img src="/images/hero5.jpg" alt="" />
    </div>

    <div class="hero-inner container-content relative z-10">
      <div class="max-w-4xl fade-up">
        <p class="eyebrow mb-8">Sikkim, India</p>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-light tracking-tight text-ink leading-[1.05] text-balance mb-10">
          Single-village honey from <em class="text-honey not-italic">Sikkim's</em> protected forests.
        </h1>
        <p class="text-lg md:text-xl text-ink-soft max-w-xl leading-relaxed mb-12">
          From the only fully organic state in India. Harvested by 125 verified beekeepers across four districts. Every jar traceable to its village.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/honey" class="btn-primary">Shop the Honey</a>
          <a href="/story" class="btn-ghost">Our Story</a>
        </div>
      </div>
    </div>

    <button type="button" class="hero-prev" aria-label="Previous hero image">&larr;</button>
    <button type="button" class="hero-next" aria-label="Next hero image">&rarr;</button>
  </section>

  <!-- ====================================================================
       THE LAND — short paragraph, sets terroir
       ==================================================================== -->
  <section class="bg-cream-deep section" data-reveal>
    <div class="container-content grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-5">
        <p class="eyebrow mb-6">The Land</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light text-ink leading-tight tracking-tight text-balance">
          India's only fully organic state.
        </h2>
      </div>
      <div class="md:col-span-6 md:col-start-7">
        <p class="text-lg text-ink-soft leading-relaxed mb-6">
          Sikkim spans the eastern Himalayas, from sub-tropical river valleys at 700m to alpine pasture at 6,000m. In 2016 it became the first — and still only — Indian state to declare itself fully organic. No chemical fertilizers. No pesticides. No exceptions.
        </p>
        <p class="text-lg text-ink-soft leading-relaxed mb-8">
          For bees, this is everything. The forage is uncontaminated, the biodiversity is intact, and the honey reflects the forest unmediated.
        </p>
        <a href="/story" class="btn-ghost">Read the Story</a>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       SIKKIM MAP COMPONENT — the Araku-style interactive
       ==================================================================== -->
  <section class="container-content section" data-reveal>
    <div class="grid md:grid-cols-12 gap-12 items-center">

      <!-- Left: text -->
      <div class="md:col-span-5">
        <p class="eyebrow mb-6">Four Districts. Four Villages.</p>
        <h2 class="font-serif text-3xl md:text-4xl font-light text-ink leading-tight tracking-tight text-balance mb-6">
          Every jar carries a village name. Every village has a story.
        </h2>
        <p class="text-base text-ink-soft leading-relaxed mb-8">
          We don't blend honey across regions. Each harvest is bottled separately, by village, so you taste the forest exactly where it grew.
        </p>
        <p class="text-base text-ink-soft leading-relaxed">
          Tap a region to see where your honey comes from.
        </p>
      </div>

      <!-- Right: interactive map placeholder -->
      <div class="md:col-span-7">
        <!-- District toggle dots -->
        <div class="flex items-center justify-end gap-6 mb-6">
          {(['North', 'East', 'West', 'South'] as const).map((dir) => (
            <button
              type="button"
              data-district={dir}
              class="district-btn group flex flex-col items-center gap-2"
              aria-label={`Show ${dir} Sikkim`}
            >
              <span class="w-3 h-3 rounded-full bg-ink-fade group-hover:bg-honey transition-colors duration-400"></span>
              <span class="text-tiny uppercase tracking-widest text-ink-mute group-hover:text-ink transition-colors duration-400">{dir}</span>
            </button>
          ))}
        </div>

        <!-- Map placeholder — replace with actual SVG map illustration -->
        <div class="img-placeholder aspect-[4/3] w-full relative">
          <div class="absolute inset-0 flex items-center justify-center text-center px-8">
            <div>
              <p class="font-serif text-2xl text-ink-mute mb-2" id="district-label">Tap a district</p>
              <p class="text-tiny uppercase tracking-widest text-ink-mute">
                [ Hand-drawn Sikkim map SVG goes here ]
              </p>
            </div>
          </div>
        </div>

        <!-- Village reveal area -->
        <div id="village-reveal" class="mt-6 min-h-[60px]">
          <!-- Populated by script below -->
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       FEATURED HONEY — 3 SKUs, flagship first
       ==================================================================== -->
  <section class="bg-cream-deep section" data-reveal>
    <div class="container-content">
      <div class="flex items-end justify-between mb-16">
        <div>
          <p class="eyebrow mb-4">The Honey</p>
          <h2 class="font-serif text-4xl md:text-5xl font-light text-ink tracking-tight text-balance">
            Two villages live. Two more on the way.
          </h2>
        </div>
        <a href="/honey" class="hidden md:inline-flex btn-ghost">View All</a>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        {featured.map((h) => (
          <article class="group relative">
            {!h.available && (
              <span class="absolute top-4 left-4 z-10 inline-block text-tiny uppercase tracking-widest bg-cream text-honey border border-honey px-3 py-1">
                Coming Soon
              </span>
            )}
            <a href={`/honey/${h.slug}`} class="block no-underline">
              <div class="aspect-[4/5] w-full mb-5 overflow-hidden bg-cream-paper border border-ink-fade/30">
              <JarSilhouette
                village={h.village}
                district={`${h.district} Sikkim`}
                comingSoon={!h.available}
              />
              </div>
            </a>
            <p class="eyebrow mb-2">{h.districtFull}</p>
            <a href={`/honey/${h.slug}`} class="no-underline">
              <h3 class="font-serif text-2xl font-normal text-ink mb-2 group-hover:text-honey transition-colors duration-400">
                {h.name}
              </h3>
            </a>
            <p class="text-sm text-ink-soft mb-4 leading-relaxed">{h.oneLiner}</p>
            {h.available ? (
              <>
              <p class="text-sm text-ink font-medium" data-price data-price-inr={h.sizes[0].priceINR} data-price-usd={h.sizes[0].priceUSD}>
                ₹{h.sizes[0].priceINR}
                <span class="text-ink-mute font-normal text-tiny ml-1">/ {h.sizes[0].weight}</span>
              </p>
                <button
                  type="button"
                  class="snipcart-add-item btn-primary mt-5"
                  data-item-id={h.slug}
                  data-item-name={h.name}
                  data-item-price={h.sizes[0].priceINR}
                  data-item-url={`/honey/${h.slug}`}
                >
                  Add to Cart
                </button>
              </>
            ) : (
              <p class="text-tiny uppercase tracking-widest text-ink-mute">
                {h.comingSoonNote || 'Notify me when ready →'}
              </p>
            )}
          </article>
        ))}
      </div>

      <div class="mt-16 text-center md:hidden">
        <a href="/honey" class="btn-ghost">View All Honey</a>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       BEEKEEPERS PREVIEW — humanizing strip
       ==================================================================== -->
  <section class="container-content section" data-reveal>
    <div class="grid md:grid-cols-12 gap-12 items-start mb-16">
      <div class="md:col-span-6">
        <p class="eyebrow mb-6">The People</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light text-ink tracking-tight text-balance">
          {totalBeekeepers} beekeepers. The ones you meet here, chose to be here.
        </h2>
      </div>
      <div class="md:col-span-5 md:col-start-8">
        <p class="text-lg text-ink-soft leading-relaxed mb-6">
          A beekeeper's name and face on a global website is a permanent thing. We never publish either without explicit consent — collected in person, with the right to withdraw at any time. Most of our collective stays unnamed by their own choice. A few have asked to share their story.
        </p>
        <a href="/beekeepers" class="btn-ghost">Meet the Beekeepers</a>
      </div>
    </div>

    {previewBeekeepers.length > 0 && (
      <div class="grid md:grid-cols-3 gap-10 mt-16">
        {previewBeekeepers.map((b) => (
          <a href={`/beekeepers/${b.slug}`} class="group no-underline">
            {b.portrait ? (
              <div class="aspect-[3/4] w-full mb-5 overflow-hidden bg-cream-paper border border-ink-fade/30">
                <img src={b.portrait} alt={b.name} class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='<div class=\'flex items-center justify-center h-full\'><p class=\'text-tiny text-ink-mute uppercase tracking-widest\'>Portrait pending</p></div>'"/>
              </div>
            ) : (
              <div class="aspect-[3/4] w-full mb-5 bg-cream-paper border border-ink-fade/30 flex items-center justify-center">
                <p class="text-tiny text-ink-mute uppercase tracking-widest">Portrait pending</p>
              </div>
            )}
            <p class="eyebrow mb-2">{b.village}, {b.district} Sikkim</p>
            <h3 class="font-serif text-xl font-normal text-ink group-hover:text-honey transition-colors duration-400 mb-1">
              {b.name}
            </h3>
            <p class="text-sm text-ink-mute">{b.role}</p>
          </a>
        ))}
      </div>
    )}
  </section>

  <!-- ====================================================================
       TRACEABILITY TEASER — your category-defining moat
       ==================================================================== -->
  <section class="bg-ink text-cream section" data-reveal>
    <div class="container-content max-w-4xl text-center">
      <p class="eyebrow text-cream/60 mb-6">Powered by FarmLedger</p>
      <h2 class="font-serif text-4xl md:text-6xl font-light tracking-tight leading-[1.1] text-balance mb-8 text-cream">
        Scan the jar. Meet your beekeeper.
      </h2>
      <p class="text-lg text-cream/80 leading-relaxed max-w-2xl mx-auto mb-12">
        Every ApiCare jar carries a unique code. Scan it with your phone and see exactly who harvested your honey, when, where, and how it was tested.
      </p>
      <a href="/traceability" class="inline-flex items-center justify-center px-8 py-3.5 bg-cream text-ink text-sm font-medium tracking-wide uppercase no-underline hover:bg-honey hover:text-cream transition-all duration-400 ease-editorial">
        See How It Works
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const images = document.querySelectorAll(".hero-slider img");
    let index = 0;

    function show(i) {
      images.forEach(img => img.classList.remove("active"));
      images[i].classList.add("active");
    }

    document.querySelector(".hero-next")?.addEventListener("click", () => {
      index = (index + 1) % images.length;
      show(index);
    });

    document.querySelector(".hero-prev")?.addEventListener("click", () => {
      index = (index - 1 + images.length) % images.length;
      show(index);
    });
  });
</script>

<script>
  // ========================================================================
  // District Toggle — placeholder behavior
  // Will be replaced with real SVG map highlight logic in Day 6
  // ========================================================================
  type District = 'North' | 'East' | 'West' | 'South';

  const villageData: Record<District, { villages: string[]; href: string }> = {
    North: { villages: ['Dzongu'], href: '/honey/dzongu-north' },
    East:  { villages: ['Zitlang'], href: '/honey/zitlang-pakyong' },
    West:  { villages: ['Yuksom'],  href: '/honey/yuksom-west' },
    South: { villages: ['Kewzing'], href: '/honey/kewzing-south' },
  };

  const buttons = document.querySelectorAll<HTMLButtonElement>('.district-btn');
  const label = document.getElementById('district-label');
  const reveal = document.getElementById('village-reveal');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const district = btn.dataset.district as District | undefined;
      if (!district) return;

      // Update visual state on dots
      buttons.forEach((b) => {
        const dot = b.querySelector('span:first-child');
        const txt = b.querySelector('span:last-child');
        const isActive = b === btn;
        dot?.classList.toggle('bg-honey', isActive);
        dot?.classList.toggle('bg-ink-fade', !isActive);
        txt?.classList.toggle('text-ink', isActive);
        txt?.classList.toggle('text-ink-mute', !isActive);
      });

      // Update label
      if (label) {
        label.textContent = `${district} Sikkim`;
        label.className = 'font-serif text-3xl text-ink mb-2';
      }

      // Update village reveal
      const data = villageData[district];
      if (reveal && data) {
        reveal.innerHTML = `
          <div class="border-t border-ink-fade/40 pt-5 flex items-center justify-between">
            <div>
              <p class="text-tiny uppercase tracking-widest text-ink-mute mb-1">Source village</p>
              <p class="font-serif text-2xl text-ink">${data.villages.join(', ')}</p>
            </div>
            <a href="${data.href}" class="text-tiny uppercase tracking-widest text-ink no-underline border-b border-ink hover:text-honey hover:border-honey transition-all duration-300">
              See the Honey →
            </a>
          </div>
        `;
      }
    });
  });
</script>
